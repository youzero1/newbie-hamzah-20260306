'-')
  ) {
    const op = tokens[pos.index].value;
    pos.index++;
    const right = parseTerm(tokens, pos);
    if (op === '+') left += right;
    else left -= right;
  }

  return left;
}

function parseTerm(tokens: Token[], pos: { index: number }): number {
  let left = parseFactor(tokens, pos);

  while (
    pos.index < tokens.length &&
    tokens[pos.index].type === 'operator' &&
    (tokens[pos.index].value